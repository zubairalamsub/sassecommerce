# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=order_db
DB_SSLMODE=disable

# Kafka Configuration
KAFKA_ENABLED=true
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=order-events
KAFKA_CONSUMER_GROUP=order-service-projections

# External Services
INVENTORY_SERVICE_URL=http://inventory-service:8080
PAYMENT_SERVICE_URL=http://payment-service:8080

# Logging
LOG_LEVEL=info
