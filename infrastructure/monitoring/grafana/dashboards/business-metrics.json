{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "── Orders ──",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": { "mode": "markdown", "content": "## Order Metrics" }
    },
    {
      "title": "Orders Created (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 2 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"order-service\", handler=~\".*create.*\", status=\"200\"}[5m]))",
          "legendFormat": "Orders/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "color": { "fixedColor": "green", "mode": "fixed" }
        }
      }
    },
    {
      "title": "Order API Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 2 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"order-service\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"order-service\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"order-service\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Order Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 2 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"order-service\", status=~\"4..|5..\"}[5m])) by (status)",
          "legendFormat": "{{ status }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "title": "── Payments ──",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 10 },
      "options": { "mode": "markdown", "content": "## Payment Metrics" }
    },
    {
      "title": "Payment Requests (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"payment-service\", status=\"200\"}[5m]))",
          "legendFormat": "Successful"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"payment-service\", status=~\"4..|5..\"}[5m]))",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Payment Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"payment-service\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Payment Service Up",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "targets": [
        { "expr": "up{job=\"payment-service\"}", "legendFormat": "Status" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "title": "── Users & Auth ──",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 20 },
      "options": { "mode": "markdown", "content": "## Users & Authentication" }
    },
    {
      "title": "Auth Requests (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"user-service\"}[5m]))",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Auth Errors (401/403)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 22 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"user-service\", status=~\"401|403\"}[5m]))",
          "legendFormat": "Auth failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      }
    },
    {
      "title": "User Service Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"user-service\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "── Products & Search ──",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 30 },
      "options": { "mode": "markdown", "content": "## Products & Search" }
    },
    {
      "title": "Product API Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"product-service\"}[5m])) by (handler)",
          "legendFormat": "{{ handler }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Search Queries (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 32 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"search-service\"}[5m]))",
          "legendFormat": "Searches/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Cart Operations (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"cart-service\"}[5m])) by (handler)",
          "legendFormat": "{{ handler }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "── Kafka Event Flow ──",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 40 },
      "options": { "mode": "markdown", "content": "## Event Streaming" }
    },
    {
      "title": "Events per Topic (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "targets": [
        {
          "expr": "sum(rate(kafka_topic_partition_current_offset[5m])) by (topic)",
          "legendFormat": "{{ topic }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Consumer Lag by Group",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "targets": [
        {
          "expr": "kafka_consumergroup_lag_sum",
          "legendFormat": "{{ consumergroup }} / {{ topic }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ecommerce", "business"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Business Metrics",
  "uid": "business-metrics"
}
